{
  "name": "bitget-client",
  "version": "1.1.1",
  "description": "Bitget CLI tool — bgc",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "bgc": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bitget",
    "cli",
    "bgc",
    "trading"
  ],
  "dependencies": {
    "bitget-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "bitget-test-utils": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
