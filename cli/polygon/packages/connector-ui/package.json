{
  "name": "@polygonlabs/agent-connector-ui",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "description": "Wallet connector UI for Polygon Agent Kit - creates secure encrypted wallet sessions",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xPolygon/polygon-agent-cli",
    "directory": "packages/connector-ui"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "start": "serve dist -s -l ${PORT:-3000}",
    "postinstall": "(cp -n .env.example .env) || echo already exists",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0xsequence/dapp-client": "3.0.0-beta.16",
    "@0xsequence/wallet-primitives": "3.0.0-beta.16",
    "@tailwindcss/vite": "^4.1.18",
    "lucide-react": "^0.564.0",
    "ox": "^0.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serve": "^14.2.4",
    "tailwindcss": "^4",
    "tweetnacl": "^1.0.3",
    "tweetnacl-sealedbox-js": "^1.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0",
    "wrangler": "^4.67.0"
  }
}
